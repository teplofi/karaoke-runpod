# Скопируй в .env и впиши свои значения. Файл .env в git НЕ попадает.
RUNPOD_API_KEY=впиши_ключ_из_RunPod
RUNPOD_ENDPOINT_ID=впиши_id_эндпоинта
KARAOKE_DIR=/var/www/claude-test
PUBLIC_BASE=https://nonstopplay.ru
# через сколько часов авто-удалять готовые караоке-страницы (cleanup.sh по крону)
KARAOKE_TTL_HOURS=48
